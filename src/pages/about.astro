---
import BaseLayout from '../layouts/BaseLayout.astro';

const history = [
  { year: '2004', ko: '보고텍 설립 · 시배콘 냅코(CIVACON KNAPPCO, USA) 대리점', en: 'Established BOGOTEC · Distributor of CIVACON KNAPPCO, USA' },
  { year: '2007', ko: '커스텀 호이스트(Custom Hoists, USA) 대리점', en: 'Distributor of Custom Hoists, USA' },
  { year: '2009', ko: '펜타(HS PENTA, ITALY) 대리점', en: 'Distributor of HS PENTA, Italy' },
  { year: '2011', ko: '케이비(주)로 법인 전환 및 상호 변경', en: 'Incorporated and renamed as KB, Inc. (KBI)' },
  { year: '2012', ko: '베벨러(VDL Weweler, NETHERLANDS) 대리점', en: 'Distributor of VDL Weweler, Netherlands' },
  { year: '2013', ko: '아이피에이치-하이드로카·하이드로벤(IPH-Hydrocar, Hydroven, ITALY) 대리점', en: 'Distributor of IPH-Hydrocar & Hydroven, Italy' },
  { year: '2014', ko: '푸와·샌드(FUWA·SAND, CHINA) 및 발랙스(VALX, NETHERLANDS) 대리점', en: 'Distributor of FUWA & SAND, China and VALX, Netherlands' },
  { year: '2016', ko: '필립스(PHILLIPS Industries, USA) 및 트럭-라이트(Truck-Lite, UK) 대리점', en: 'Distributor of PHILLIPS Industries, USA and Truck-Lite, UK' },
  { year: '2018', ko: '아살리 스테펜-알오알(Assali Stefen-ROR, ITALY) 대리점', en: 'Distributor of Assali Stefen ROR, Italy' },
];
---
<BaseLayout
  title="회사소개 | 케이비(주) KB Inc."
  description="케이비(주) 개요와 연혁. 2004년 설립, CIVACON 탱커 부품에서 트레일러 핵심 부품까지 — 검증된 글로벌 브랜드를 국내에 공급합니다."
  active="about"
>
  <!-- PAGE HEADER -->
  <section class="border-b border-hairline-steel relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-graphite-surface opacity-40 -skew-x-12 translate-x-1/3 pointer-events-none"></div>
    <div class="relative z-10 max-w-container mx-auto px-gutter pt-20 pb-16" data-reveal>
      <p class="font-mono text-[13px] text-arterial-red mb-4 flex items-center gap-3"><span class="w-8 h-px bg-arterial-red"></span>회사소개 / ABOUT</p>
      <h1 class="font-display font-bold text-bright-alloy tracking-tightest text-[clamp(2.2rem,5vw,3.6rem)] leading-[1.1]">
        <span data-ko-only>케이비 주식회사</span><span data-en-only>KB Inc.</span>
      </h1>
      <p class="text-muted-zinc text-lg mt-5 max-w-2xl leading-relaxed">
        <span data-ko-only>고객만족을 최우선으로, 최고의 품질과 경쟁력 있는 가격, 책임지는 서비스로 함께합니다.</span>
        <span data-en-only>Customer satisfaction first — top quality, competitive pricing, and accountable service.</span>
      </p>
    </div>
  </section>

  <!-- INTRODUCTION (개요) -->
  <section id="intro" class="border-b border-hairline-steel scroll-mt-16">
    <div class="max-w-container mx-auto px-gutter py-section-v grid lg:grid-cols-[minmax(0,22rem)_1fr] gap-10 lg:gap-20">
      <div data-reveal>
        <p class="font-mono text-[13px] text-arterial-red mb-3">01 / INTRODUCTION</p>
        <h2 class="font-display font-bold text-3xl text-bright-alloy"><span data-ko-only>회사 개요</span><span data-en-only>Introduction</span></h2>
      </div>
      <div class="flex flex-col gap-6 text-lg leading-relaxed" data-reveal>
        <p class="text-bright-alloy font-medium">
          <span data-ko-only>케이비(주)(구 보고텍)는 2004년에 설립되어, 도버(DOVER) 그룹 산하 OPW 글로벌의 일부인 시배콘 냅코(CIVACON KNAPPCO) 탱커 제품을 국내 탱크로리 제작업체에 공급하며 출발했습니다.</span>
          <span data-en-only>KB, Inc. (KBI, formerly BOGOTEC) was established in 2004, supplying tanker components to tanker builders as the distributor of CIVACON KNAPPCO (USA) — part of OPW Global under the Dover group, specialized in products and systems to safely load, monitor, and unload petroleum, dry-bulk, and petrochemical cargo tanks.</span>
        </p>
        <p class="text-muted-zinc">
          <span data-ko-only>시배콘과 함께 정유사들의 하부 적재 시스템(Bottom Loading System)의 한국 표준 제정에 참여하고 탱크로리 제작업체들의 시스템 장착에 협력했으며, 항공(Aviation)·케미칼(Chemical)·드라이 벌크(Dry Bulk)·유류(Petroleum) 및 LPG용 고품질 탱커 부품을 공급하여 왔습니다.</span>
          <span data-en-only>Together with CIVACON, KBI helped major refineries set the Korean standard for the Bottom Loading System (BLS) and supported tanker builders in installing it — supplying quality tanker components for aviation, chemical, dry-bulk, petroleum, and LPG tankers.</span>
        </p>
        <p class="text-muted-zinc">
          <span data-ko-only>2007년부터는 트레일러 제작업체에 트레일러 부품을 공급하기 시작했습니다. 인터펌프(INTERPUMP) 그룹 산하 IPH의 일부인 텔레스코픽 실린더 전문 제조사 펜타(HS Penta), 트레일러·트럭·버스용 (에어)서스펜션 설계·제작사인 VDL 그룹의 베벨러(VDL Weweler) 제품으로 라인업을 확장했으며, 푸와(FUWA)·알오알(ROR)·발랙스(VALX) 등 우수한 트레일러 액슬과 샌드(SAND) 브레이크 부스터, 트럭-라이트(Truck-Lite) 비전 시스템을 공급하여 왔습니다.</span>
          <span data-en-only>Since 2007 KBI has gradually shifted to trailer parts — distributing Custom Hoists (US), a leading manufacturer of mobile hydraulic cylinders; HS Penta (IT), telescopic-cylinder specialists now part of IPH under the Interpump Group; and VDL Weweler (NL), a leading designer and manufacturer of (air) suspension solutions for trailers, trucks, and buses. The lineup expanded with proven trailer axles from FUWA (CN), ROR (IT), and VALX (NL), plus SAND (CN) brake chambers and boosters and Truck-Lite (UK) vision systems.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- HISTORY (연혁) -->
  <section id="history" class="border-b border-hairline-steel scroll-mt-16">
    <div class="max-w-container mx-auto px-gutter py-section-v grid lg:grid-cols-[minmax(0,22rem)_1fr] gap-10 lg:gap-20">
      <div data-reveal>
        <p class="font-mono text-[13px] text-arterial-red mb-3">02 / HISTORY</p>
        <h2 class="font-display font-bold text-3xl text-bright-alloy"><span data-ko-only>연혁</span><span data-en-only>History</span></h2>
        <p class="text-muted-zinc mt-4 leading-relaxed">
          <span data-ko-only>2004년 설립 이후, 세계적 브랜드들과의 파트너십을 꾸준히 넓혀 왔습니다.</span>
          <span data-en-only>Since 2004, we have steadily broadened our partnerships with world-class brands.</span>
        </p>
      </div>
      <ol class="relative border-l border-hairline-steel flex flex-col">
        {history.map((h) => (
          <li class="relative pl-10 py-5 group hover:bg-graphite-surface/40 transition-colors" data-reveal>
            <span class="absolute left-0 top-[2.05rem] -translate-x-1/2 w-2 h-2 bg-arterial-red rotate-45 group-hover:scale-125 transition-transform"></span>
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-8">
              <span class="font-mono text-arterial-red text-lg font-bold tracking-tight shrink-0 w-16">{h.year}</span>
              <p class="text-bright-alloy leading-relaxed"><span data-ko-only>{h.ko}</span><span data-en-only>{h.en}</span></p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- BUSINESS OVERVIEW -->
  <section class="border-b border-hairline-steel">
    <div class="max-w-container mx-auto px-gutter py-section-v">
      <div class="mb-14" data-reveal>
        <p class="font-mono text-[13px] text-arterial-red mb-3">03 / BUSINESS</p>
        <h2 class="font-display font-bold text-3xl text-bright-alloy"><span data-ko-only>사업개요</span><span data-en-only>Business Overview</span></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-px bg-hairline-steel border border-hairline-steel">
        <div class="bg-charcoal-void p-8 flex flex-col gap-4" data-reveal>
          <span class="font-mono text-[13px] text-arterial-red">A / AIR SUSPENSION</span>
          <h3 class="font-display font-bold text-xl text-bright-alloy"><span data-ko-only>에어서스펜션</span><span data-en-only>Air Suspension</span></h3>
          <p class="text-muted-zinc leading-relaxed text-[15px]">
            <span data-ko-only>100년이 넘는 역사의 네덜란드 VDL Weweler사의 최신 기술로 생산된 신뢰성 있는 제품을 공급합니다. 유럽 시장 점유율 30% 이상, 자동화된 최신 설비에서 생산되어 전 세계에 수출됩니다.</span>
            <span data-en-only>Reliable products from the Netherlands' VDL Weweler, with over 100 years of history and a 30%+ European market share, produced in automated facilities and exported worldwide.</span>
          </p>
        </div>
        <div class="bg-charcoal-void p-8 flex flex-col gap-4" data-reveal>
          <span class="font-mono text-[13px] text-arterial-red">B / AXLES &amp; LANDING LEGS</span>
          <h3 class="font-display font-bold text-xl text-bright-alloy"><span data-ko-only>액슬 · 랜딩 레그</span><span data-en-only>Axles &amp; Landing Legs</span></h3>
          <p class="text-muted-zinc leading-relaxed text-[15px]">
            <span data-ko-only>네덜란드에서 설계·시험된 푸와-발랙스(FUWA-VALX)의 디스크 브레이크 액슬(DISK 430/370)을 공급합니다. 유지보수 프리 설계에 WABCO 캘리퍼를 표준 장착했으며, VALX 랜딩 레그도 취급 예정입니다.</span>
            <span data-en-only>FUWA-VALX disc-brake axles (DISK 430/370), designed and tested in the Netherlands — maintenance-free with WABCO callipers as standard. VALX landing legs are coming soon.</span>
          </p>
        </div>
        <div class="bg-charcoal-void p-8 flex flex-col gap-4" data-reveal>
          <span class="font-mono text-[13px] text-arterial-red">C / FULL LINEUP</span>
          <h3 class="font-display font-bold text-xl text-bright-alloy"><span data-ko-only>전체 라인업</span><span data-en-only>Full Lineup</span></h3>
          <p class="text-muted-zinc leading-relaxed text-[15px]">
            <span data-ko-only>자매회사 파코(PKI)와 함께 전동 유압 펌프(Hydroven), 브레이크 부스터(SAND), 하네스·라이팅(PHILLIPS, Truck-Lite), 타이어·휠, 탱커 부품(CIVACON) 등 폭넓은 제품군을 공급합니다.</span>
            <span data-en-only>Together with sister company PKI, we supply a broad range — electric pumps (Hydroven), brake boosters (SAND), harness &amp; lighting (PHILLIPS, Truck-Lite), tires &amp; wheels, and tanker equipment (CIVACON).</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CORE VALUES -->
  <section class="border-b border-hairline-steel">
    <div class="max-w-container mx-auto px-gutter py-16 border-b border-hairline-steel" data-reveal>
      <p class="font-mono text-[13px] text-arterial-red mb-3">04 / CORE VALUES</p>
      <h2 class="font-display font-bold text-bright-alloy tracking-tightest text-[clamp(1.8rem,4vw,2.8rem)]">
        <span data-ko-only>세 가지 약속</span><span data-en-only>Three Commitments</span>
      </h2>
    </div>
    <div class="max-w-container mx-auto px-gutter">
      <div class="border-b border-hairline-steel py-12 grid md:grid-cols-[minmax(0,20rem)_1fr] gap-6 md:gap-16 items-baseline group hover:bg-graphite-surface/40 transition-colors -mx-gutter px-gutter" data-reveal>
        <h3 class="font-display font-bold text-2xl md:text-3xl text-bright-alloy flex items-center gap-4"><span class="font-mono text-sm text-arterial-red">A</span><span data-ko-only>최고의 품질</span><span data-en-only>Top Quality</span></h3>
        <p class="text-muted-zinc leading-relaxed">
          <span data-ko-only>특장차 제작에서 부품의 품질은 차량 품질을 좌우하는 가장 기본적인 요소입니다. 오랜 전통을 지닌 유럽·미국의 검증된 공급처로부터 설계·개발·생산·품질관리까지 최고의 기술과 최첨단 장비로 만든 제품을 공급하며, 모든 제품은 전 세계 시장에서 오랜 기간 양산되며 검증되었습니다.</span>
          <span data-en-only>Component quality is the foundation of vehicle quality. We supply products engineered, developed, built, and quality-controlled by established European and American manufacturers — each proven through years of volume production in markets worldwide.</span>
        </p>
      </div>
      <div class="border-b border-hairline-steel py-12 grid md:grid-cols-[minmax(0,20rem)_1fr] gap-6 md:gap-16 items-baseline group hover:bg-graphite-surface/40 transition-colors -mx-gutter px-gutter" data-reveal>
        <h3 class="font-display font-bold text-2xl md:text-3xl text-bright-alloy flex items-center gap-4"><span class="font-mono text-sm text-arterial-red">B</span><span data-ko-only>경쟁력 있는 가격</span><span data-en-only>Competitive Price</span></h3>
        <p class="text-muted-zinc leading-relaxed">
          <span data-ko-only>우수한 품질에도 높은 가격이 부담이던 유럽·미국산 제품을, 오랜 국제무역 경험을 바탕으로 운송비 절감·운송 절차 간소화 등 부대비용을 최소화해 가격 경쟁력을 확보했습니다. 북미에 이어 유럽과 체결한 자유무역협정으로 관세도 꾸준히 낮아지고 있습니다.</span>
          <span data-en-only>Years of international-trade experience minimize freight and handling costs, while free-trade agreements with North America and Europe continue to lower tariffs — bringing premium European and American products within competitive reach.</span>
        </p>
      </div>
      <div class="border-b border-hairline-steel py-12 grid md:grid-cols-[minmax(0,20rem)_1fr] gap-6 md:gap-16 items-baseline group hover:bg-graphite-surface/40 transition-colors -mx-gutter px-gutter" data-reveal>
        <h3 class="font-display font-bold text-2xl md:text-3xl text-bright-alloy flex items-center gap-4"><span class="font-mono text-sm text-arterial-red">C</span><span data-ko-only>책임지는 서비스</span><span data-en-only>Accountable Service</span></h3>
        <p class="text-muted-zinc leading-relaxed">
          <span data-ko-only>서비스란 제품의 적용 검토 단계부터 발주, 납품, 사후관리에 이르는 전반적인 과정에서 제공되는 일련의 관리입니다. 고객 입장에서 생각하는, 찾아가는 서비스, 책임지는 서비스로 고객만족을 위하여 최선을 다하겠습니다.</span>
          <span data-en-only>Service is the full chain of care — from application review to ordering, delivery, and after-sales support. We do our utmost for customer satisfaction with proactive, customer-first, accountable service.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-arterial-red">
    <div class="max-w-container mx-auto px-gutter py-16 flex flex-col md:flex-row items-center justify-between gap-8">
      <h2 class="font-display font-bold text-bright-alloy tracking-tightest text-[clamp(1.6rem,3.5vw,2.4rem)]">
        <span data-ko-only>제품이 궁금하신가요?</span><span data-en-only>Curious about our products?</span>
      </h2>
      <a href="/products" class="inline-flex items-center gap-2 border border-bright-alloy text-bright-alloy font-mono text-sm px-8 py-4 hover:bg-bright-alloy hover:text-arterial-red active:translate-y-px transition-all">
        <span data-ko-only>제품 보기</span><span data-en-only>VIEW PRODUCTS</span><span class="material-symbols-outlined text-[18px]">arrow_forward</span>
      </a>
    </div>
  </section>
</BaseLayout>
