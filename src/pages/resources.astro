---
import BaseLayout from '../layouts/BaseLayout.astro';

const catalogs = [
  {
    file: '/catalogs/valx-product-brochure-2023.pdf',
    logo: '/assets/img/valx_logo.gif',
    logoAlt: 'VALX',
    brand: 'VALX',
    ko: 'VALX 제품 카탈로그',
    en: 'VALX Product Brochure',
    descKo: '드럼·디스크 액슬 전 라인업 사양과 적용 가이드',
    descEn: 'Full drum & disc axle lineup — specs and application guide',
    year: '2023',
    pages: 10,
    size: '5.1 MB',
  },
  {
    file: '/catalogs/vdl-weweler-mbs-omega-flyer-2024.pdf',
    logo: '/assets/img/VDL_Weweler_logo.gif',
    logoAlt: 'VDL Weweler',
    brand: 'VDL WEWELER',
    ko: 'MBS 오메가 플라이어',
    en: 'MBS Omega Flyer',
    descKo: '트레일러용 MBS 오메가 에어서스펜션 소개 자료',
    descEn: 'MBS Omega air-suspension system for trailers',
    year: '2024',
    pages: 2,
    size: '0.7 MB',
  },
  {
    file: '/catalogs/vdl-weweler-truck-bus-flyer-2024.pdf',
    logo: '/assets/img/VDL_Weweler_logo.gif',
    logoAlt: 'VDL Weweler',
    brand: 'VDL WEWELER',
    ko: '트럭·버스 플라이어',
    en: 'Truck & Bus Flyer',
    descKo: '트럭·버스용 서스펜션 솔루션 소개 자료',
    descEn: 'Suspension solutions for trucks and buses',
    year: '2024',
    pages: 2,
    size: '0.7 MB',
  },
];

const hssGroups = [
  {
    key: 'FUEL SIDE',
    ko: '연료 시스템',
    en: 'Fuel system',
    docs: [
      { file: '/catalogs/hss-diesel-maintenance-plan.pdf', ko: '디젤 유지관리 플랜 (3-Step)', en: 'Diesel Maintenance Plan (3-Step)', size: '0.9 MB' },
      { file: '/catalogs/hss-diesel-additive-comparison.pdf', ko: '디젤 첨가제 성분 비교 차트', en: 'Diesel Additive Comparison Chart', size: '2.7 MB' },
      { file: '/catalogs/hss-diesel-extreme-cetane-comparison.pdf', ko: 'Diesel Extreme 세탄 부스트 비교', en: 'Diesel Extreme Cetane Comparison', size: '2.5 MB' },
      { file: '/catalogs/hss-edt-additive-comparison.pdf', ko: 'EDT 첨가제 비교 차트', en: 'EDT Additive Comparison Chart', size: '0.1 MB' },
      { file: '/catalogs/hss-de-motortrend-review.pdf', ko: 'MotorTrend 디젤 첨가제 리뷰', en: 'MotorTrend Diesel Additive Review', size: '0.2 MB' },
    ],
  },
  {
    key: 'OIL SIDE',
    ko: '오일 시스템',
    en: 'Oil system',
    docs: [
      { file: '/catalogs/hss-fr3-friction-reducer.pdf', ko: 'FR3 프릭션 리듀서 소개', en: 'FR3 Friction Reducer', size: '2.4 MB' },
      { file: '/catalogs/hss-fr3-nano-technology.pdf', ko: 'FR3 나노 테크놀로지', en: 'FR3 Nano Technology', size: '1.1 MB' },
      { file: '/catalogs/hss-stiction-removal-astm-test.pdf', ko: '스틱션 세정력 제3자 시험 (ASTM D4828)', en: 'Stiction Removal — 3rd-Party ASTM Test', size: '2.8 MB' },
      { file: '/catalogs/hss-se-3rd-party-testing.pdf', ko: 'Stiction Eliminator 제3자 시험 기사', en: 'Stiction Eliminator 3rd-Party Testing', size: '2.5 MB' },
      { file: '/catalogs/hss-se-tested-proven.pdf', ko: 'Stiction Eliminator 성능 검증 자료', en: 'Stiction Eliminator — Tested & Proven', size: '2.8 MB' },
      { file: '/catalogs/hss-se-dyno-proven.pdf', ko: 'Stiction Eliminator 다이노 시험 결과', en: 'Stiction Eliminator — Dyno Proven', size: '1.7 MB' },
    ],
  },
  {
    key: '2-STEP',
    ko: '2-Step 프로그램',
    en: '2-Step program',
    docs: [
      { file: '/catalogs/hss-2step-complete-protection.pdf', ko: '2-Step 토탈 케어 프로그램', en: '2-Step Complete Protection', size: '1.3 MB' },
      { file: '/catalogs/hss-2step-oil-fuel-treatment.pdf', ko: '2-Step 연료·오일 트리트먼트', en: '2-Step Fuel & Oil Treatment', size: '1.1 MB' },
      { file: '/catalogs/hss-fuel-economy-study.pdf', ko: '연비 개선 실증 시험 (오하이오 주립대)', en: 'Fuel-Economy Study (Ohio State Univ.)', size: '1.0 MB' },
    ],
  },
];
---
<BaseLayout
  title="자료실 | 케이비(주) KB Inc. — 제품 카탈로그·기술 자료"
  description="케이비(주) 자료실. VALX 액슬, VDL Weweler 에어서스펜션 카탈로그와 Hot Shot's Secret 디젤 첨가제 기술 자료를 열람하고 다운로드하세요."
  active="resources"
>
  <!-- PAGE HEADER -->
  <section class="border-b border-hairline-steel relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-graphite-surface opacity-40 -skew-x-12 translate-x-1/3 pointer-events-none"></div>
    <div class="relative z-10 max-w-container mx-auto px-gutter pt-20 pb-16" data-reveal>
      <p class="font-mono text-[13px] text-arterial-red mb-4 flex items-center gap-3"><span class="w-8 h-px bg-arterial-red"></span>자료실 / RESOURCES</p>
      <h1 class="font-display font-bold text-bright-alloy tracking-tightest text-[clamp(2.2rem,5vw,3.6rem)] leading-[1.1]">
        <span data-ko-only>제품 카탈로그</span><span data-en-only>Product Catalogs</span>
      </h1>
      <p class="text-muted-zinc text-lg mt-5 max-w-2xl leading-relaxed">
        <span data-ko-only>브랜드별 공식 카탈로그를 사이트에서 바로 열람하거나 PDF로 다운로드하실 수 있습니다.</span>
        <span data-en-only>Browse official brand catalogs right on the site, or download them as PDF.</span>
      </p>
    </div>
  </section>

  <!-- CATALOG GRID -->
  <section class="border-b border-hairline-steel">
    <div class="max-w-container mx-auto px-gutter py-section-v">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-hairline-steel border border-hairline-steel">
        {catalogs.map((c) => (
          <article class="bg-charcoal-void flex flex-col group" data-reveal>
            <a
              href={c.file}
              target="_blank"
              rel="noopener"
              data-pdf
              data-title-ko={c.ko}
              data-title-en={c.en}
              data-brand={c.brand}
              class="relative h-44 bg-[#F5F5F5] flex items-center justify-center overflow-hidden cursor-pointer"
              aria-label={`${c.brand} ${c.ko} 열람`}
            >
              <img src={c.logo} alt={c.logoAlt} class="max-h-12 w-auto opacity-90 group-hover:scale-105 transition-transform duration-500" />
              <span class="absolute inset-0 bg-charcoal-void/0 group-hover:bg-charcoal-void/55 transition-colors flex items-center justify-center">
                <span class="opacity-0 group-hover:opacity-100 transition-opacity inline-flex items-center gap-2 font-mono text-[13px] text-bright-alloy border border-bright-alloy px-5 py-2.5">
                  <span class="material-symbols-outlined text-[18px]">visibility</span>
                  <span data-ko-only>바로 보기</span><span data-en-only>VIEW</span>
                </span>
              </span>
              <span class="absolute top-3 left-3 font-mono text-[10px] tracking-[0.15em] text-charcoal-void/60 border border-charcoal-void/20 px-2 py-0.5">PDF</span>
            </a>
            <div class="p-7 flex flex-col gap-3 flex-grow">
              <p class="font-mono text-[11px] tracking-[0.2em] text-arterial-red">{c.brand} · {c.year}</p>
              <h2 class="font-display font-bold text-xl text-bright-alloy leading-snug">
                <span data-ko-only>{c.ko}</span><span data-en-only>{c.en}</span>
              </h2>
              <p class="text-muted-zinc text-[14.5px] leading-relaxed">
                <span data-ko-only>{c.descKo}</span><span data-en-only>{c.descEn}</span>
              </p>
              <p class="font-mono text-[12px] text-muted-zinc mt-1">
                {c.pages}<span data-ko-only>페이지</span><span data-en-only> pages</span> · {c.size}
              </p>
              <div class="flex items-stretch gap-3 mt-4 pt-4 border-t border-hairline-steel">
                <a
                  href={c.file}
                  target="_blank"
                  rel="noopener"
                  data-pdf
                  data-title-ko={c.ko}
                  data-title-en={c.en}
                  data-brand={c.brand}
                  class="flex-grow inline-flex items-center justify-center gap-2 bg-arterial-red text-bright-alloy font-mono text-[13px] px-5 py-3 hover:bg-arterial-red-dim active:translate-y-px transition-all"
                >
                  <span class="material-symbols-outlined text-[18px]">import_contacts</span>
                  <span data-ko-only>바로 보기</span><span data-en-only>VIEW</span>
                </a>
                <a
                  href={c.file}
                  download
                  class="inline-flex items-center justify-center gap-2 border border-hairline-steel text-muted-zinc font-mono text-[13px] px-4 py-3 hover:border-arterial-red hover:text-bright-alloy active:translate-y-px transition-all"
                  aria-label={`${c.brand} ${c.ko} 다운로드`}
                >
                  <span class="material-symbols-outlined text-[18px]">download</span>
                  <span data-ko-only>다운로드</span><span data-en-only>DOWNLOAD</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="font-mono text-[13px] text-muted-zinc mt-8 flex items-center gap-2" data-reveal>
        <span class="material-symbols-outlined text-[16px]">info</span>
        <span data-ko-only>필요한 자료가 더 있으신가요? <a href="/contact" class="text-bright-alloy underline underline-offset-4 hover:text-arterial-red transition-colors">문의하기</a>로 요청해 주세요.</span>
        <span data-en-only>Need more materials? <a href="/contact" class="text-bright-alloy underline underline-offset-4 hover:text-arterial-red transition-colors">Contact us</a> and we'll send them over.</span>
      </p>
    </div>
  </section>

  <!-- HOT SHOT'S SECRET TECH LIBRARY -->
  <section id="hss" class="border-b border-hairline-steel scroll-mt-16">
    <div class="max-w-container mx-auto px-gutter py-section-v">
      <div class="mb-12" data-reveal>
        <p class="font-mono text-[13px] text-arterial-red mb-3">HOT SHOT'S SECRET</p>
        <h2 class="font-display font-bold text-3xl text-bright-alloy tracking-tightest">
          <span data-ko-only>디젤 첨가제 기술 자료</span><span data-en-only>Diesel additive tech library</span>
        </h2>
        <p class="text-muted-zinc mt-4 max-w-2xl leading-relaxed">
          <span data-ko-only>Hot Shot's Secret 제품별 소개 자료와 제3자 시험 결과, 경쟁 제품 비교 차트를 확인하실 수 있습니다. 제품 상세는 <a href="/products#additives" class="text-bright-alloy underline underline-offset-4 hover:text-arterial-red transition-colors">제품소개</a>에서 보실 수 있습니다.</span>
          <span data-en-only>Product literature, third-party test results, and competitor comparison charts for Hot Shot's Secret. See the <a href="/products#additives" class="text-bright-alloy underline underline-offset-4 hover:text-arterial-red transition-colors">products page</a> for details.</span>
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-hairline-steel border border-hairline-steel" data-reveal>
        {hssGroups.map((g) => (
          <div class="bg-charcoal-void p-8 flex flex-col">
            <p class="font-mono text-[11px] tracking-[0.2em] text-arterial-red mb-1">{g.key}</p>
            <h3 class="font-display font-bold text-lg text-bright-alloy mb-4"><span data-ko-only>{g.ko}</span><span data-en-only>{g.en}</span></h3>
            <div class="flex flex-col">
              {g.docs.map((d) => (
                <div class="flex items-center justify-between gap-3 border-t border-hairline-steel py-3.5">
                  <a
                    href={d.file}
                    target="_blank"
                    rel="noopener"
                    data-pdf
                    data-title-ko={d.ko}
                    data-title-en={d.en}
                    data-brand="HOT SHOT'S SECRET"
                    class="group flex-grow min-w-0 cursor-pointer"
                  >
                    <span class="block font-mono text-[13px] text-muted-zinc group-hover:text-bright-alloy transition-colors leading-snug"><span data-ko-only>{d.ko}</span><span data-en-only>{d.en}</span></span>
                    <span class="block font-mono text-[11px] text-muted-zinc/60 mt-0.5">PDF · {d.size}</span>
                  </a>
                  <div class="flex items-center gap-1.5 shrink-0">
                    <a
                      href={d.file}
                      target="_blank"
                      rel="noopener"
                      data-pdf
                      data-title-ko={d.ko}
                      data-title-en={d.en}
                      data-brand="HOT SHOT'S SECRET"
                      class="inline-flex items-center justify-center w-9 h-9 border border-hairline-steel text-muted-zinc hover:border-arterial-red hover:text-bright-alloy transition-colors"
                      aria-label={`${d.ko} 열람`}
                    ><span class="material-symbols-outlined text-[16px]">visibility</span></a>
                    <a
                      href={d.file}
                      download
                      class="inline-flex items-center justify-center w-9 h-9 border border-hairline-steel text-muted-zinc hover:border-arterial-red hover:text-bright-alloy transition-colors"
                      aria-label={`${d.ko} 다운로드`}
                    ><span class="material-symbols-outlined text-[16px]">download</span></a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
      <p class="font-mono text-[12px] text-muted-zinc mt-6 flex items-center gap-2" data-reveal>
        <span class="material-symbols-outlined text-[15px]">language</span>
        <span data-ko-only>원문 자료(영문) — 제조사 LSI(Lubrication Specialties Inc.) 제공. 공식 홈페이지: <a href="https://hotshotsecret.com/" target="_blank" rel="noopener" class="text-bright-alloy underline underline-offset-4 hover:text-arterial-red transition-colors">hotshotsecret.com</a></span>
        <span data-en-only>Original materials in English, provided by LSI (Lubrication Specialties Inc.). Official site: <a href="https://hotshotsecret.com/" target="_blank" rel="noopener" class="text-bright-alloy underline underline-offset-4 hover:text-arterial-red transition-colors">hotshotsecret.com</a></span>
      </p>
    </div>
  </section>

  <!-- OFFICIAL BRAND LINKS -->
  <section class="border-b border-hairline-steel">
    <div class="max-w-container mx-auto px-gutter py-section-v">
      <div class="mb-12" data-reveal>
        <p class="font-mono text-[13px] text-arterial-red mb-3">OFFICIAL LINKS</p>
        <h2 class="font-display font-bold text-3xl text-bright-alloy tracking-tightest">
          <span data-ko-only>브랜드 공식 자료</span><span data-en-only>Official brand resources</span>
        </h2>
        <p class="text-muted-zinc mt-4 max-w-2xl leading-relaxed">
          <span data-ko-only>제조사 공식 홈페이지에서 최신 개발 소식, 기술 자료, 매뉴얼을 확인하실 수 있습니다.</span>
          <span data-en-only>Find the latest developments, technical documents, and manuals on the manufacturers' official websites.</span>
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-px bg-hairline-steel border border-hairline-steel" data-reveal>
        <div class="bg-charcoal-void p-8 flex flex-col gap-5">
          <div class="h-12 flex items-center"><img src="/assets/img/VDL_Weweler_logo.gif" alt="VDL Weweler" class="max-h-8 w-auto bg-[#F5F5F5] px-3 py-1.5" /></div>
          <div class="flex flex-col">
            <a href="https://www.vdlweweler.nl/products/developments" target="_blank" rel="noopener" class="group flex items-center justify-between gap-4 border-t border-hairline-steel py-4 font-mono text-[13px] text-muted-zinc hover:text-bright-alloy transition-colors">
              <span><span data-ko-only>제품 개발 동향</span><span data-en-only>Product developments</span></span>
              <span class="material-symbols-outlined text-[16px] group-hover:text-arterial-red group-hover:translate-x-0.5 transition-all">open_in_new</span>
            </a>
            <a href="https://www.vdlweweler.nl/services/rolling-road" target="_blank" rel="noopener" class="group flex items-center justify-between gap-4 border-t border-hairline-steel py-4 font-mono text-[13px] text-muted-zinc hover:text-bright-alloy transition-colors">
              <span><span data-ko-only>롤링 로드 테스트 서비스</span><span data-en-only>Rolling road test service</span></span>
              <span class="material-symbols-outlined text-[16px] group-hover:text-arterial-red group-hover:translate-x-0.5 transition-all">open_in_new</span>
            </a>
            <a href="https://www.vdlweweler.nl/support/downloads" target="_blank" rel="noopener" class="group flex items-center justify-between gap-4 border-t border-hairline-steel py-4 font-mono text-[13px] text-muted-zinc hover:text-bright-alloy transition-colors">
              <span><span data-ko-only>기술 자료 다운로드</span><span data-en-only>Technical downloads</span></span>
              <span class="material-symbols-outlined text-[16px] group-hover:text-arterial-red group-hover:translate-x-0.5 transition-all">open_in_new</span>
            </a>
          </div>
        </div>
        <div class="bg-charcoal-void p-8 flex flex-col gap-5">
          <div class="h-12 flex items-center"><img src="/assets/img/valx_logo.gif" alt="VALX" class="max-h-9 w-auto bg-[#F5F5F5] px-3 py-1.5" /></div>
          <div class="flex flex-col">
            <a href="https://www.valx.eu/en/products/" target="_blank" rel="noopener" class="group flex items-center justify-between gap-4 border-t border-hairline-steel py-4 font-mono text-[13px] text-muted-zinc hover:text-bright-alloy transition-colors">
              <span><span data-ko-only>제품 라인업</span><span data-en-only>Product lineup</span></span>
              <span class="material-symbols-outlined text-[16px] group-hover:text-arterial-red group-hover:translate-x-0.5 transition-all">open_in_new</span>
            </a>
            <a href="https://www.valx.eu/en/service/spare-parts/" target="_blank" rel="noopener" class="group flex items-center justify-between gap-4 border-t border-hairline-steel py-4 font-mono text-[13px] text-muted-zinc hover:text-bright-alloy transition-colors">
              <span><span data-ko-only>스페어 파츠</span><span data-en-only>Spare parts</span></span>
              <span class="material-symbols-outlined text-[16px] group-hover:text-arterial-red group-hover:translate-x-0.5 transition-all">open_in_new</span>
            </a>
            <a href="https://www.valx.eu/en/service/manuals/" target="_blank" rel="noopener" class="group flex items-center justify-between gap-4 border-t border-hairline-steel py-4 font-mono text-[13px] text-muted-zinc hover:text-bright-alloy transition-colors">
              <span><span data-ko-only>매뉴얼</span><span data-en-only>Manuals</span></span>
              <span class="material-symbols-outlined text-[16px] group-hover:text-arterial-red group-hover:translate-x-0.5 transition-all">open_in_new</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PDF VIEWER MODAL (PDF.js custom renderer — works on every device) -->
  <div id="pdf-modal" class="fixed inset-0 z-[100] flex flex-col bg-charcoal-void/90 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300" role="dialog" aria-modal="true" aria-labelledby="pdf-modal-title">
    <div class="flex items-center justify-between gap-3 h-16 px-4 md:px-8 border-b border-hairline-steel bg-charcoal-void shrink-0">
      <div class="flex items-baseline gap-3 md:gap-4 min-w-0">
        <span id="pdf-modal-brand" class="hidden sm:inline font-mono text-[11px] tracking-[0.2em] text-arterial-red whitespace-nowrap"></span>
        <h2 id="pdf-modal-title" class="font-display font-bold text-bright-alloy text-[15px] md:text-lg truncate"></h2>
      </div>
      <div class="flex items-center gap-1.5 md:gap-2 shrink-0">
        <div class="hidden md:flex items-center border border-hairline-steel">
          <button id="pdf-zoom-out" class="w-9 h-9 flex items-center justify-center text-muted-zinc hover:text-bright-alloy transition-colors" aria-label="축소"><span class="material-symbols-outlined text-[18px]">remove</span></button>
          <span id="pdf-zoom-label" class="font-mono text-[11px] text-muted-zinc w-12 text-center select-none">100%</span>
          <button id="pdf-zoom-in" class="w-9 h-9 flex items-center justify-center text-muted-zinc hover:text-bright-alloy transition-colors" aria-label="확대"><span class="material-symbols-outlined text-[18px]">add</span></button>
        </div>
        <span id="pdf-page-label" class="font-mono text-[11px] text-muted-zinc px-2 whitespace-nowrap select-none">– / –</span>
        <a id="pdf-modal-download" href="#" download class="inline-flex items-center gap-2 h-9 font-mono text-[12px] text-muted-zinc border border-hairline-steel px-3 hover:border-arterial-red hover:text-bright-alloy transition-colors">
          <span class="material-symbols-outlined text-[16px]">download</span>
          <span class="hidden lg:inline"><span data-ko-only>다운로드</span><span data-en-only>DOWNLOAD</span></span>
        </a>
        <a id="pdf-modal-newtab" href="#" target="_blank" rel="noopener" class="hidden sm:inline-flex items-center justify-center w-9 h-9 font-mono text-[12px] text-muted-zinc border border-hairline-steel hover:border-arterial-red hover:text-bright-alloy transition-colors" aria-label="새 탭에서 열기">
          <span class="material-symbols-outlined text-[16px]">open_in_new</span>
        </a>
        <button id="pdf-modal-close" class="inline-flex items-center justify-center text-bright-alloy border border-hairline-steel w-9 h-9 hover:border-arterial-red hover:text-arterial-red transition-colors" aria-label="닫기">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
    </div>
    <div id="pdf-scroll" class="flex-grow relative overflow-y-auto overscroll-contain bg-graphite-surface">
      <div id="pdf-loading" class="absolute inset-0 flex flex-col items-center justify-center gap-4 pointer-events-none">
        <span class="pdf-spinner"></span>
        <p class="font-mono text-[13px] text-muted-zinc"><span data-ko-only>카탈로그를 불러오는 중</span><span data-en-only>Loading catalog</span> <span id="pdf-progress"></span></p>
      </div>
      <div id="pdf-pages" class="flex flex-col items-center gap-5 px-4 py-8"></div>
    </div>
  </div>

  <script>
    // In-site PDF viewer, rendered page-by-page with PDF.js onto canvases —
    // consistent full-document viewing on desktop and mobile alike (iOS Safari
    // can't scroll iframe-embedded PDFs, so we draw them ourselves). The library
    // is dynamically imported on first open, so the page itself stays light.
    const modal = document.getElementById('pdf-modal') as HTMLElement;
    const scroller = document.getElementById('pdf-scroll') as HTMLElement;
    const pagesEl = document.getElementById('pdf-pages') as HTMLElement;
    const loadingEl = document.getElementById('pdf-loading') as HTMLElement;
    const progressEl = document.getElementById('pdf-progress') as HTMLElement;
    const titleEl = document.getElementById('pdf-modal-title') as HTMLElement;
    const brandEl = document.getElementById('pdf-modal-brand') as HTMLElement;
    const pageLabel = document.getElementById('pdf-page-label') as HTMLElement;
    const zoomLabel = document.getElementById('pdf-zoom-label') as HTMLElement;
    const dlEl = document.getElementById('pdf-modal-download') as HTMLAnchorElement;
    const ntEl = document.getElementById('pdf-modal-newtab') as HTMLAnchorElement;
    const closeBtn = document.getElementById('pdf-modal-close') as HTMLButtonElement;

    let pdfjsPromise: Promise<any> | null = null;
    function loadPdfjs() {
      if (!pdfjsPromise) {
        pdfjsPromise = (async () => {
          const [pdfjs, worker] = await Promise.all([
            import('pdfjs-dist'),
            import('pdfjs-dist/build/pdf.worker.min.mjs?url'),
          ]);
          pdfjs.GlobalWorkerOptions.workerSrc = (worker as any).default;
          return pdfjs;
        })();
      }
      return pdfjsPromise;
    }

    let currentDoc: any = null;
    let currentTask: any = null;
    let renderToken = 0;
    let openSeq = 0;
    let zoom = 1;

    function fitWidth() {
      // page width that fills the scroller, capped for readability on wide screens
      return Math.min(scroller.clientWidth - 32, 920);
    }

    async function renderDoc() {
      if (!currentDoc) return;
      const doc = currentDoc;
      const token = ++renderToken;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      pagesEl.replaceChildren();
      try {
        for (let i = 1; i <= doc.numPages; i++) {
          if (token !== renderToken) return; // superseded by zoom/close/reopen
          const page = await doc.getPage(i);
          if (token !== renderToken) return;
          const base = page.getViewport({ scale: 1 });
          const scale = (fitWidth() / base.width) * zoom;
          const vp = page.getViewport({ scale });
          const canvas = document.createElement('canvas');
          canvas.width = Math.floor(vp.width * dpr);
          canvas.height = Math.floor(vp.height * dpr);
          canvas.style.width = vp.width + 'px';
          canvas.style.height = vp.height + 'px';
          canvas.className = 'pdf-page-canvas';
          canvas.dataset.page = String(i);
          pagesEl.appendChild(canvas);
          await page.render({
            canvasContext: canvas.getContext('2d'),
            viewport: vp,
            transform: dpr !== 1 ? [dpr, 0, 0, dpr, 0, 0] : undefined,
          }).promise;
          if (i === 1) loadingEl.style.display = 'none';
        }
      } catch (e) {
        // a superseded run's in-flight render rejects on cancel — not a failure
        if (token === renderToken) throw e;
      }
    }

    function setZoom(z: number) {
      zoom = Math.min(2.5, Math.max(0.5, z));
      zoomLabel.textContent = Math.round(zoom * 100) + '%';
      renderDoc();
    }

    function updatePageLabel() {
      if (!currentDoc) return;
      const mid = scroller.scrollTop + scroller.clientHeight / 2;
      let cur = 1;
      pagesEl.querySelectorAll('canvas').forEach((c) => {
        if ((c as HTMLElement).offsetTop <= mid) cur = Number((c as HTMLElement).dataset.page);
      });
      pageLabel.textContent = cur + ' / ' + currentDoc.numPages;
    }
    scroller.addEventListener('scroll', updatePageLabel, { passive: true });

    async function openViewer(url: string, ko: string, en: string, brand: string) {
      const myOpen = ++openSeq;
      const isEn = document.documentElement.classList.contains('lang-en');
      titleEl.textContent = isEn ? en : ko;
      brandEl.textContent = brand;
      dlEl.href = url;
      ntEl.href = url;
      pageLabel.textContent = '– / –';
      progressEl.textContent = '';
      loadingEl.style.display = '';
      pagesEl.replaceChildren();
      modal.classList.remove('opacity-0', 'pointer-events-none');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
      try {
        const pdfjs = await loadPdfjs();
        const task = pdfjs.getDocument({ url });
        currentTask = task;
        task.onProgress = (p: any) => {
          if (p.total) progressEl.textContent = Math.round((p.loaded / p.total) * 100) + '%';
        };
        currentDoc = await task.promise;
        zoom = 1;
        zoomLabel.textContent = '100%';
        pageLabel.textContent = '1 / ' + currentDoc.numPages;
        await renderDoc();
      } catch (err) {
        // Only fall back when THIS open attempt genuinely failed — a close or
        // reopen mid-render also rejects, and must not spawn a stray tab.
        if (myOpen !== openSeq) return;
        closeViewer();
        window.open(url, '_blank', 'noopener');
      }
    }

    function closeViewer() {
      openSeq++;
      renderToken++;
      modal.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
      currentDoc = null;
      if (currentTask) { try { currentTask.destroy(); } catch (e) {} currentTask = null; }
      // let the fade-out finish before dropping the canvases
      setTimeout(() => { if (!currentDoc) pagesEl.replaceChildren(); }, 300);
    }

    document.querySelectorAll<HTMLAnchorElement>('[data-pdf]').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        openViewer(a.getAttribute('href') || '', a.dataset.titleKo || '', a.dataset.titleEn || '', a.dataset.brand || '');
      });
    });

    closeBtn.addEventListener('click', closeViewer);
    modal.addEventListener('click', (e) => {
      if (e.target === modal || e.target === scroller || e.target === pagesEl) closeViewer();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('opacity-0')) closeViewer();
    });
    (document.getElementById('pdf-zoom-in') as HTMLButtonElement).addEventListener('click', () => setZoom(zoom + 0.25));
    (document.getElementById('pdf-zoom-out') as HTMLButtonElement).addEventListener('click', () => setZoom(zoom - 0.25));

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      if (!currentDoc || modal.classList.contains('opacity-0')) return;
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(renderDoc, 250);
    });
  </script>
</BaseLayout>
